  "envContract": {
    "requiredForLiveOnly": [
      "TREASURY_WALLET_ADDRESS",
      "TREASURY_CHAIN_ID",
      "WALLET_PROVIDER",
      "WALLET_BALANCE_API_URL",
      "SETTLEMENTS_API_URL",
      "LIVE_OPPORTUNITIES_URL",
      "OPENAI_RESPONSES_PROXY_URL",
      "N8N_AGENT_RUN_WEBHOOK_URL"
    ],
    "phaseAAdditional": [
      "REDIS_HOST",
      "REDIS_PORT",
      "POSTGRES_USER",
      "POSTGRES_PASSWORD",
      "POSTGRES_DB",
      "POSTGRES_PORT",
      "OPENAI_API_KEY",
      "OPENAI_MODEL",
      "OPERATOR_PRIVATE_KEY"
    ]
  },
  "cutoverOrder": [
    "Deploy longscale app or mobile app",
    "Import n8n workflow JSON",
    "Add OpenAI credentials in n8n / provider proxy",
    "Point HTTP nodes at deployed app endpoints",
    "Replace mock telemetry with live webhook/queue metrics",
    "Bind ledger and mission bus to persistent storage",
    "Enable Treasury and Settlement upstreams",
    "Only then re-enable any declared scanner/predictor/generator/shipper roles"
  ],
  "doNotShip": [
    "fabricated revenue numbers",
    "simulated wallet balances",
    "worldsim outputs presented as live truth",
    "declared-only agents masquerading as connected services"
  ]
}